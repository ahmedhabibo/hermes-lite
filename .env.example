# Hermes-Lite Environment Template (v0.8.0+)
# ============================================
# Copy this file to ``.env`` and fill in your credentials.
# No Hermes Agent dependency. All vars use the ``HERMES_LITE_`` prefix.

# --- Local LLM (llama.cpp server) ---
HERMES_LITE_LOCAL_URL=http://127.0.0.1:8080/v1
HERMES_LITE_LOCAL_MODEL=Qwen2.5-Coder-7B-Instruct-IQ3_XS.gguf

# --- Cloud LLM (NVIDIA NIM Free API) ---
HERMES_LITE_CLOUD_URL=https://integrate.api.nvidia.com/v1
HERMES_LITE_CLOUD_MODEL=z-ai/glm-5.2

# Single API key:
HERMES_LITE_NVIDIA_API_KEY=

# Or pipe/comma-separated pool for rotation:
# HERMES_LITE_NVIDIA_API_KEYS=key1|key2|key3

# --- Rate limiting (NIM Free = 40 RPM per key) ---
HERMES_LITE_RPM=40
HERMES_LITE_MAX_RETRIES=4

# --- Router ---
# LITE_LOCAL_MAX_COMPLEXITY=0.3

# --- MoA (Mixture of Agents) ---
# HERMES_LITE_MOA_PRESET=council
# HERMES_LITE_MOA_TIMEOUT_S=60
# HERMES_LITE_MOA_REF_TEMPERATURE=0.4
# HERMES_LITE_MOA_AGG_TEMPERATURE=0.2
# HERMES_LITE_MOA_MAX_TOKENS=4096

# --- Memory ---
# LITE_MEMORY_MAX_CHARS=800

# --- Subagent ---
# HERMES_LITE_SUBAGENT_MODEL=local:Qwen2.5-Coder-7B-Instruct-IQ3_XS.gguf
# HERMES_LITE_SUBAGENT_TIMEOUT=180

# --- Orchestrator ---
# HERMES_LITE_MAX_ITERATIONS=12

# --- Tools ---
# Set to 1 to enable tools on the local endpoint (PEG grammar; can crash small models):
# HERMES_LITE_LOCAL_TOOLS=0

# Disable standalone web tools:
# HERMES_LITE_WEB_SEARCH_DISABLED=0
# HERMES_LITE_WEB_FETCH_DISABLED=0

# Sandbox:
# HERMES_LITE_SANDBOX_ALLOWLIST="ls,cat,grep,rg,pwd,echo,curl"
# HERMES_LITE_SANDBOX_TIMEOUT=60
